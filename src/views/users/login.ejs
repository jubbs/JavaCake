<div class="auth-container">
  <div class="auth-box">
    <h1>Login</h1>
    <p class="subtitle">Welcome back! Please login to your account.</p>

    <%- FormHelper.create('/users/login', { class: 'auth-form' }) %>
      <div class="form-group">
        <%- FormHelper.label('email', 'Email') %>
        <%- FormHelper.input('email', {
          type: 'email',
          placeholder: 'Enter your email',
          class: 'form-control',
          required: true
        }) %>
      </div>

      <div class="form-group">
        <%- FormHelper.label('password', 'Password') %>
        <%- FormHelper.input('password', {
          type: 'password',
          placeholder: 'Enter your password',
          class: 'form-control',
          required: true
        }) %>
      </div>

      <div class="form-group">
        <%- FormHelper.submit('Login', { class: 'btn btn-primary btn-block' }) %>
      </div>
    <%- FormHelper.end() %>

    <p class="auth-footer">
      Don't have an account?
      <%- HtmlHelper.link('Register here', '/users/register') %>
    </p>
  </div>
</div>
