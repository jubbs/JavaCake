{
  "name": "javacake",
  "version": "1.0.0",
  "description": "A CakePHP-inspired MVC framework for Node.js with convention over configuration",
  "main": "webroot/index.js",
  "scripts": {
    "start": "node webroot/index.js",
    "dev": "nodemon webroot/index.js",
    "test": "jest",
    "migrate": "node bin/migrate.js up",
    "migrate:up": "node bin/migrate.js up",
    "migrate:down": "node bin/migrate.js down",
    "migrate:create": "node bin/migrate.js create",
    "migrate:reset": "node bin/migrate.js reset"
  },
  "keywords": [
    "mvc",
    "framework",
    "cakephp",
    "mysql",
    "orm",
    "convention"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "db-migrate": "^0.11.14",
    "db-migrate-mysql": "^3.0.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mysql2": "^3.6.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  }
}
